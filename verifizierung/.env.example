# Umgebungsvariablen der APP (in Coolify unter "Environment Variables" setzen).
#
# Ohne diese Variablen läuft die App auch – dann aber nur mit STUN
# (weniger zuverlässig in Mobilfunk-/Firmennetzen).

# Passwort für den Moderator-Zugang. PFLICHT – ohne dieses kann sich niemand
# als Moderator einloggen (die Bewerber-Seite bleibt offen). Frei wählbar.
MODERATOR_PASSWORD=hier_dein_moderator_passwort

# Muss IDENTISCH sein mit TURN_SECRET beim coturn-Dienst.
TURN_SECRET=hier_dein_langes_geheimnis_einsetzen

# DNS-Name (oder IP) des TURN-Servers – zeigt auf denselben Hetzner-Server.
TURN_HOST=verify.4ever1.tv

# Optional: Gültigkeitsdauer der TURN-Zugangsdaten in Sekunden (Standard 3600).
# TURN_TTL=3600

# Optional: eigene STUN-Server (Komma-getrennt). Standard sind Google-STUN.
# STUN_URLS=stun:verify.4ever1.tv:3478

# --- Accounts / Speicher ---------------------------------------------------
# Verzeichnis für gespeicherte Codes/Accounts/Fotos. In Coolify auf ein
# Persistent Volume legen (z. B. /data), sonst sind die Daten nach einem
# Redeploy weg.
DATA_DIR=/data

# Schlüssel zum VERSCHLÜSSELN aller gespeicherten Daten (Ausweis-Fotos UND
# Account-Metadaten wie Namen/Ausweis-Nr.). Erzeugen z. B. mit:
#   openssl rand -hex 32
# WICHTIG: Schlüssel SICHER aufbewahren und NICHT ändern!
#  - Ohne den Schlüssel sind die Daten nicht mehr lesbar.
#  - Mit FALSCHEM Schlüssel startet der Server bewusst NICHT (Schutz vor
#    versehentlichem Überschreiben).
STORAGE_KEY=hier_dein_daten_schluessel

# --- 2FA (optional, empfohlen) ---------------------------------------------
# base32-Secret für die Authenticator-App des Moderators. Leer = nur Passwort.
# Erzeugen mit:  npm run totp
# MODERATOR_TOTP_SECRET=ABCDEFGHIJKLMNOP

# Der Port wird von Coolify gesetzt; lokal Standard 3000.
# PORT=3000
