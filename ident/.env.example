# ==== ident – Umgebungsvariablen ====
# Diese Datei nach .env kopieren und ausfüllen. NIEMALS echte Werte committen.

# Port (Coolify/Reverse-Proxy leitet 443 -> hier)
PORT=8080

# Verzeichnis für die (verschlüsselten) Daten. In der Cloud auf ein DAUERHAFTES
# Volume legen, sonst sind die Daten nach einem Neustart weg.
DATA_DIR=/data

# PFLICHT für den Echtbetrieb: Schlüssel für die Verschlüsselung ruhender Daten
# (AES-256-GCM). Lange, zufällige Passphrase. Ohne diesen Wert werden Daten
# UNVERSCHLÜSSELT gespeichert (der Server warnt beim Start).
STORAGE_KEY=

# Admin-Passwort (Zugang zum Admin-Panel /admin und zum Anlegen von Prüfern).
ADMIN_PASSWORD=

# Admin-2FA (TOTP, base32). DRINGEND empfohlen. Mit `npm run` bzw. einem
# Authenticator einrichten; leer = 2FA aus.
ADMIN_TOTP_SECRET=

# Optional: Login nur von bestimmten IPs erlauben (kommagetrennt). Leer = überall.
LOGIN_ALLOW_IPS=

# TURN-Server für zuverlässiges Video hinter strengen Firewalls (empfohlen).
# Ohne TURN klappt Video in vielen Firmen-/Mobilfunknetzen nicht.
TURN_HOST=
TURN_SECRET=
TURN_TTL=3600
